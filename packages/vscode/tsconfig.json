{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "./out",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "declaration": true,
    "paths": {
      "@codelens-ai/core": ["./src/codelens-ai-core.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "out"]
}
